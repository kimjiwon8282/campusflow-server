SPRING_PROFILES_ACTIVE=local

DB_URL=jdbc:mysql://localhost:3306/campusflow?serverTimezone=Asia/Seoul&useUnicode=true&characterEncoding=utf8&connectionCollation=utf8mb4_unicode_ci
DB_USERNAME=
DB_PASSWORD=

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TOKEN_VALIDITY_MS=1800000
JWT_REFRESH_TOKEN_VALIDITY_MS=1296000000

ACCESS_TOKEN_COOKIE_NAME=ACCESS_TOKEN
REFRESH_TOKEN_COOKIE_NAME=REFRESH_TOKEN
CSRF_TOKEN_COOKIE_NAME=XSRF-TOKEN
CSRF_HEADER_NAME=X-XSRF-TOKEN

COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=Lax
ACCESS_TOKEN_COOKIE_MAX_AGE_SECONDS=1800
REFRESH_TOKEN_COOKIE_MAX_AGE_SECONDS=1296000

CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=true

REFRESH_TOKEN_CLEANUP_ENABLED=true
REFRESH_TOKEN_CLEANUP_CRON=0 0 3 * * *
REFRESH_TOKEN_REVOKED_RETENTION_DAYS=7
